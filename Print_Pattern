//Program : A C program to display the following pattern.
5 4 3 2 1
  4 3 2 1 
    3 2 1
      2 1
        1


#include<stdio.h>
int main()
{
	int X;
	for(int i=5;i>0;i--)
	{
          X = i;
          printf("%d\t",X);
	}
	printf(    "\n");
	for(int j=4;j>0;j--)
	{
			printf("\t%d",j);
	}	
	printf("\n\t");
	for(int k=3;k>0;k--)
	{
		printf("\t%d",k);
	}
	printf("\n\t\t");
	for(int l=2;l>0;l--)
	{
			printf("\t%d",l);
	}
	printf("\n\t\t\t\t");
	printf("1");
			
	return 0;
}
