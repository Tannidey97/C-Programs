/Program : A program to print inventory stock report using some sample data.

#include<stdio.h>
int main()
{
	int x,y,z,p,q,r;
	printf("enter the item codes :");
	scanf("%d %d %d",&x,&y,&z);
	
	printf("enter the quantity of the item :");
	scanf("%d %d %d",&p,&q,&r);
	
	printf("Item code\tQuantity\tLocation\n");
	printf("%d\t\t%d\t\tjk97\n",x,p);
	printf("%d\t\t%d\t\trm96\n",y,q);
	printf("%d\t\t%d\t\tV93",z,r);
	
	return 0;
}
